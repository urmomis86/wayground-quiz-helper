{
  "manifest_version": 3,
  "name": "Wayground Quiz Helper",
  "version": "1.0",
  "description": "Auto-answer Wayground quiz questions",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://wayground.com/*",
    "https://*.wayground.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://wayground.com/*",
        "https://*.wayground.com/*"
      ],
      "js": ["wayground-content.js"],
      "run_at": "document_end",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Wayground Quiz Helper"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png", 
    "128": "icon128.png"
  }
}
